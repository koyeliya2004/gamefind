rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidPlayer(data) {
      return data.keys().hasAll(['uid', 'name', 'color', 'position', 'rotationY', 'lastSeen', 'isActive', 'health', 'maxHealth'])
        && data.keys().size() == 9
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 64
        && data.color is string && data.color.matches('^#[A-Fa-f0-9]{6}$')
        && data.position is map
        && data.rotationY is number
        && data.lastSeen == request.time
        && data.isActive == true
        && data.health is number && data.health >= 0 && data.health <= data.maxHealth
        && data.maxHealth is number && data.maxHealth > 0;
    }

    // --- Collections ---
    match /test/connection {
      allow get: if isSignedIn();
    }

    match /players/{playerId} {
      allow get: if isSignedIn() && isValidId(playerId);
      allow list: if isSignedIn() && resource.data.isActive == true;

      allow create: if isSignedIn()
        && isValidId(playerId)
        && playerId == request.auth.uid
        && isValidPlayer(incoming());

      allow update: if isSignedIn()
        && isValidId(playerId)
        && (
          // Case 1: Owner updates their state
          (playerId == request.auth.uid && (
             // Allow partial or full updates as long as identity and basic sanity is preserved
             incoming().uid == request.auth.uid &&
             incoming().health >= 0
          )) ||
          // Case 2: Someone deals damage (only updating health)
          (incoming().diff(existing()).affectedKeys().hasOnly(['health']) && incoming().health < existing().health)
        );

      allow delete: if isSignedIn()
        && isValidId(playerId)
        && playerId == request.auth.uid;
    }
  }
}
